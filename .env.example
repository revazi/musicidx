# MusicIdx local development configuration.
# Copy to .env and fill in local paths/keys as needed.
# Do not commit .env.

# Local storage defaults. Leave blank to use project-local defaults.
MUSICIDX_DB_PATH=
MUSICIDX_MODELS_PATH=

# Optional explicit binary paths if ffprobe/fpcalc are not on PATH.
MUSICIDX_FFPROBE_PATH=
MUSICIDX_FPCALC_PATH=

# Optional Gemini intent parsing. Used only when --llm is passed.
GEMINI_API_KEY=
MUSICIDX_GEMINI_MODEL=gemini-2.0-flash
MUSICIDX_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional OpenAI intent parsing. Use with --llm-provider openai.
OPENAI_API_KEY=
MUSICIDX_OPENAI_MODEL=gpt-4o-mini
MUSICIDX_OPENAI_BASE_URL=https://api.openai.com/v1

# Optional desktop development overrides.
MUSICIDX_CLI_PATH=uv
MUSICIDX_CLI_PREFIX_ARGS=run musicidx
MUSICIDX_WORKING_DIR=
