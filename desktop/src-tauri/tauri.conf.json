{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MusicIdx",
  "version": "0.1.0",
  "identifier": "local.musicidx.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MusicIdx",
        "width": 1120,
        "height": 820,
        "minWidth": 760,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Music"
  }
}
